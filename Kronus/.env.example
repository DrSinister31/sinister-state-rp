# ============================================================================
# KRONUS — Sinister State Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# Supabase
SUPABASE_URL=https://yqfzaugbrwoluhkddcsh.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Deepseek AI (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Redis (Railway auto-provides REDIS_URL on free tier)
REDIS_URL=redis://localhost:6379

# RCON (via Supabase command queue — synix_bridge reads rcon_commands table)
RCON_HOST=79.127.172.121
RCON_PORT=30120
RCON_PASSWORD=your_rcon_password_here

# Discord IDs
OWNER_ID=your_discord_id_here
ADMIN_IDS=your_discord_id_here

# Channel IDs (create these in your Discord server)
LOG_CHANNEL_ID=channel_id_here
CHRONICLES_CHANNEL_ID=channel_id_here
SUPPORT_CHANNEL_ID=channel_id_here

# Role IDs (create these in your Discord server)
BUSINESS_OWNER_ROLE_ID=role_id_here
BUSINESS_EMPLOYEE_ROLE_ID=role_id_here
STAFF_ROLE_ID=role_id_here

# Tebex webhook secret
TEBEX_SECRET=your_tebex_secret_here
