# Discord OAuth (Create an app at https://discord.com/developers/applications)
# Set the redirect URI to: http://localhost:3000/api/auth/callback/discord (change localhost in production)
DISCORD_CLIENT_ID="your_discord_client_id_here"
DISCORD_CLIENT_SECRET="your_discord_client_secret_here"

# NextAuth Configuration
# Run `openssl rand -base64 32` or `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"` to generate a secret
NEXTAUTH_SECRET="your_generated_secret_here"
NEXTAUTH_URL="http://localhost:3000"
