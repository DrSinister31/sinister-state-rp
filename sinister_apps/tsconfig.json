{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@npwd/types": ["./node_modules/@npwd/types"]
    }
  },
  "include": ["src/**/*", "npwd.config.ts", "index.tsx"],
  "exclude": ["node_modules", "web"]
}
