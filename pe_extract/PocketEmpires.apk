<script>
      var state = {
    ids: ["package", "device", "sdk", "arches", "type", "dpi", "lang", "gl"],
    init() {
      var query = location.hash.slice(1);
      var params = parseQuery(query);

      for (var i = 0; i < state.ids.length; i++) {
        (function() {
          var id = state.ids[i];
          var element = document.getElementById(id);
          if(!element) return;
          state[id] = element.value;
          if (params[id]) {
            console.log(`set state ${id} -> ${params[id]}`);
            state.set(id, params[id])
            if(id === "package" && !state.init_package){
              state.init_package = params[id];
            }
          }
          document.getElementById(id).addEventListener("change", function (event){
            var value = event.target.value;
            if(id === "package" && value && (value.startsWith("https://play.google.com/store/apps/details") || value.startsWith("http://play.google.com/store/apps/details"))) {
              try{
                var uparams = parseQuery(value.split("?").slice(1)[0])
                if(uparams["id"]) value=uparams["id"];
                if(uparams["gl"] && uparams["gl"].length === 2) {
                  console.log('change state gl -> ' + uparams["gl"] );
                  state.gl= uparams["gl"]
                }
              }catch (e){}
            }

            state[id] = value;
            console.log('change state ' + id +  ' -> ' + value);
            document.getElementById('download-result').style.display = "none"
          });
        })()
      }
    },
    get: function(id) {
      return state[id]
    },
    set: function(id, value) {
      var e = document.getElementById(id);
      if (e){
        state[id]= value;
        e.value = value
      }
      return value;
    },
    getQuery(){
      var query  = "";
      for (var i = 0; i < state.ids.length; i++){
        var id = state.ids[i];
        var value = this.get(id)

        if(id === "device" && value === "default") continue
        if(id === "arches" && value === "default") continue
        if(id === "android" && value === "default") continue
        if(id === "sdk" && value === "default") continue
        if(id === "type" && value === "apk") continue
        if(id === "dpi" && value === "480") continue
        if(id === "lang" && value === "en") continue
        if(id === "gl" && (!value || value.length !== 2)) continue

        query += ((query ? "&" : "") + id + "="+ encodeURIComponent(value))
      }
      return query;
    }
  }

      state.init()
  if(state.get("package")){
    document.getElementById("download-result").style.display = "none"
    document.getElementById("download-loading").style.display = "block"
    document.getElementById("apksumbit").disabled = true;
    lazyScript("https://www.google.com/recaptcha/api.js?onload=submit&render=6LffOIUUAAAAACDGY5pUGox0yBGBUvRD8aT8c2J0")
  }

  var window_onpopstate = window.onpopstate
  window.onpopstate = function(event) {
    window_onpopstate && window_onpopstate.call(event);
    if(parseQuery(location.hash.slice(1))['package']){
        location.reload()
    }
  }

    document.getElementById("form").onsubmit = function (event){
    event.preventDefault();
    if(!state.get("package")){
      location.reload();
      return false;
    }

    if(state.init_package && state.init_package !== state.package){
      state.set("gl", "")
    }
    location.hash = state.getQuery();
    location.reload();
    return false;
  };

  function submit(){
    grecaptcha.execute('6LffOIUUAAAAACDGY5pUGox0yBGBUvRD8aT8c2J0', {action: 'apk_downloader'}).then(function(token) {
      var url = location.pathname + "?" + state.getQuery() + "&ajax=1";
      var httpRequest = new XMLHttpRequest();
      httpRequest.open("GET", url);
      httpRequest.setRequestHeader("token", token);
      httpRequest.onreadystatechange = function (){
        if (httpRequest.readyState === 4 ){
          if (httpRequest.status === 403) window.ga && window.ga("send", "event", "recaptcha", "apk_downloader", "403", "");
          document.getElementById("download-result").innerHTML = httpRequest.responseText;
          document.getElementById("download-result").style.display = "block"
          document.getElementById("download-loading").style.display = "none"
          document.getElementById("apksumbit").disabled = false;
          typeof window.octs === "function" && window.octs();
        }
      }
      httpRequest.send();
    });
  }

      function parseQuery(query){
    var params = {};
    if(!query) return params;
    var parts = query.split("&");
    for(let i = 0; i < parts.length; i++) {
      var pairs = parts[i].split("=");
      if(pairs.length === 2) params[pairs[0]] = pairs[1]
    }
    return params;
  }

  function toggleMoreSettings() {
    var $option = document.getElementById("advanced-options-content")
    var isHidden = $option.classList.contains("is-hidden");
    localStorage && localStorage.setItem("moreSettings", isHidden + '')
    document.getElementById("advanced-options-content").classList.toggle("is-hidden");
  }

  if(localStorage && localStorage.getItem("moreSettings")==="true"){
    toggleMoreSettings();
  }

